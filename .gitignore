# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# Virtual envs
.venv/
venv/
env/

# Editors / IDE
.vscode/
.idea/
*.swp
.DS_Store

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Data, models, generated outputs (keep .gitkeep)
data/generated/*
!data/generated/.gitkeep

# Large LCBV6 data blobs (>100MB, exceed GitHub file limit; regenerable from source)
data/filtered/lcbv6_non_saturated_pilot40.jsonl
data/filtered/lcbv6_informative.jsonl
data/filtered/lcbv6_hard_zero_clean.jsonl
data/filtered/lcbv6_nonsat_extra.jsonl
data/filtered/lcbv6_non_saturated.jsonl
data/filtered/lcbv6_full.jsonl
data/seeds/lcbv6_seed.jsonl
data/sft/*
!data/sft/.gitkeep
data/results/*
!data/results/.gitkeep
outputs/*
checkpoints/
wandb/

# Stray run artifacts
*.raw.json
*.log

# External clones — committed only as a pointer dir
external/*
!external/README.md
!external/.gitkeep

# Local secrets / env overrides
.env
.env.*
