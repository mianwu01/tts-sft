+
+
+# Additive M5 feedback operator (answer-hidden verdict + margin-gated population consistency;
+# see _m5_feedback_aggregate.py). Original operators above are untouched. Loaded by file path
+# because benchmark register modules are exec'd standalone (no parent package).
+import importlib.util as _ilu  # noqa: E402
+import os as _os  # noqa: E402
+
+_m5_spec = _ilu.spec_from_file_location(
